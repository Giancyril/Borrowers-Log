generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
}

enum ItemCategory {
  EQUIPMENT
  BOOKS
  OFFICE_SUPPLIES
  OTHER
}

enum BorrowStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ActivityAction {
  CREATED
  UPDATED
  RETURNED
  DELETED
  BULK_RETURNED
  BULK_DELETED
  LOGIN
  REGISTERED
  CHANGED_PASSWORD
  CHANGED_EMAIL
  CHANGED_USERNAME
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ActivityLog {
  id         String         @id @default(uuid())
  action     ActivityAction
  entityType String
  entityId   String?
  entityName String?
  details    String         @default("")
  adminId    String?
  adminName  String?
  createdAt  DateTime       @default(now())

  @@map("activityLogs")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  name      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvedRequests BorrowRecord[]   @relation("ProcessedBy")
  borrowTemplates  BorrowTemplate[]

  @@map("users")
}

model Item {
  id             String       @id @default(uuid())
  name           String
  category       ItemCategory
  description    String       @default("")
  totalQuantity  Int
  conditionNotes String       @default("")
  isDamaged      Boolean      @default(false)
  damageNotes    String       @default("")
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  borrowRecords  BorrowRecord[]
  borrowRequests BorrowRequest[]

  @@map("items")
}

model BorrowRecord {
  id String @id @default(uuid())

  // Item
  itemId           String
  item             Item   @relation(fields: [itemId], references: [id])
  quantityBorrowed Int

  // Borrower info
  borrowerName       String
  borrowerEmail      String @default("")
  borrowerDepartment String @default("")
  purpose            String @default("")

  // Dates
  borrowDate       DateTime
  dueDate          DateTime
  actualReturnDate DateTime?

  // Status
  status BorrowStatus @default(ACTIVE)

  // Condition
  conditionOnBorrow String @default("")
  conditionOnReturn String @default("")
  damageNotes       String @default("")

  // E-signatures
  borrowSignature String @default("")
  returnSignature String @default("")

  // Admin
  processedById String?
  processedBy   User?   @relation("ProcessedBy", fields: [processedById], references: [id])

  // 🔗 Linked request (1-to-1)
  request BorrowRequest?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("borrowRecords")
}

model BorrowRequest {
  id                 String @id @default(uuid())
  borrowerName       String
  borrowerEmail      String @default("")
  borrowerDepartment String @default("")
  purpose            String @default("")
  notes              String @default("")

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  quantityRequested Int
  requestedDate     DateTime @default(now())
  neededUntil       DateTime

  status          RequestStatus @default(PENDING)
  rejectionReason String        @default("")

  borrowRecordId String?       @unique
  borrowRecord   BorrowRecord? @relation(fields: [borrowRecordId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@map("borrow_requests")
}

model ReminderSettings {
  id                 String  @id @default("singleton")
  emailEnabled       Boolean @default(true)
  smsEnabled         Boolean @default(false)
  daysBefore         Int     @default(3)
  emailFromName      String  @default("NBSC SAS")
  emailSubjectPrefix String  @default("[Reminder]")

  @@map("reminder_settings")
}

model BorrowTemplate {
  id                 String   @id @default(uuid())
  name               String
  borrowerName       String   @default("")
  borrowerEmail      String   @default("")
  borrowerDepartment String   @default("")
  purpose            String   @default("")
  conditionOnBorrow  String   @default("")
  dueOffsetDays      Int      @default(7)
  createdById        String
  createdBy          User     @relation(fields: [createdById], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("borrow_templates")
}